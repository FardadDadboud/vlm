{
    "dataset": {
      "type": "SHIFT",
      "data_root": "/media/fardad/T7 Touch/SHIFT/shift-dev/data",
      "split": "val",
      "shift_filters": {
        "weather": ["clear", "overcast"],
        "time": ["daytime"],
        "max_frames_per_video": 20,
        "video_sequences": null
      },
      "max_samples": 100
    },
    "detectors": {
      "owlv2": {
        "enabled": false,
        "model_path": "google/owlv2-base-patch16-ensemble"
      },
      "grounding-dino": {
        "enabled": true,
        "model_path": "IDEA-Research/grounding-dino-base"
      }
    },
    "evaluation": {
      "output_dir": "./shift_evaluation_results",
      "strategies": ["single_best"]
    }
  }