{
  "description": "FULL TRUST mode with Gaussian STAD on OWLv2 backbone (second-detector validation)",
  "_note_unified_hyperparams": "Hyperparameters mirror global_instance_Guassian.json so the second-detector run tests transfer of TRUST without per-detector re-tuning.",
  "data_root": "/media/fardad/T7 Touch/SHIFT/shift-dev/data",
  "split": "val",
  "output_dir": "./shift_full_gaussian_owlv2_results",
  "filters": {
    "weather": [
      "clear",
      "cloudy",
      "foggy",
      "overcast",
      "rainy"
    ],
    "time": [
      "daytime"
    ],
    "max_frames_per_video": 100
  },
  "max_samples": null,
  "num_visualizations": 3000,
  "detector": {
    "name": "owlv2",
    "model_path": "google/owlv2-base-patch16-ensemble",
    "target_classes": [
      "pedestrian",
      "car",
      "truck",
      "bus",
      "motorcycle",
      "bicycle"
    ],
    "threshold": 0.1,
    "iou_threshold": 0.7
  },
  "adaptation": {
    "type": "global_instance",
    "params": {
      "mode": "full",
      "output_dir": "./shift_full_gaussian_owlv2_results",
      "_comment_mode": "=== FULL MODE: Global + Instance ===",
      "use_global_cache": true,
      "use_tracking": true,
      "use_track_stad": true,
      "_comment_global": "=== Global BCA+ Cache (BEST params from exp_id=238) ===",
      "tau1": 0.8,
      "tau1_rare_class_reduction": 0.3,
      "tau2": 0.9,
      "tau2_init": 0.8,
      "ws": 0.1,
      "logit_temperature": 10.0,
      "alpha": 0.3,
      "max_cache_size": 25,
      "use_batch_init": true,
      "batch_init_size": 10,
      "use_adapted_probs_for_cache": false,
      "_comment_lifecycle": "=== Cache Lifecycle DISABLED (matching original BCA+) ===",
      "min_hits_to_confirm_cache": 1,
      "max_age_cache": 999999,
      "_comment_tracking": "=== Tracking (from instance_only config) ===",
      "min_hits_to_confirm": 3,
      "max_age": 10,
      "feature_alpha": 0.1,
      "association_method": "bytetrack",
      "iou_threshold": 0.5,
      "high_score_threshold": 0.7,
      "low_score_threshold": 0.4,
      "track_creation_threshold": 0.65,
      "track_creation_threshold_weak": 0.35,
      "weak_cache_classes": [3, 4, 5],
      "weak_track_classes": [
        3,
        4,
        5
      ],
      "max_tracks": 100,
      "association_fast_threshold": 50,
      "aggressive_prefilter": false,
      "_comment_gaussian": "=== Gaussian STAD (BEST params from exp_id=48) ===",
      "ssm_type": "gaussian",
      "q_scale": 0.03,
      "r_base": 0.3,
      "use_diagonal_cov": true,
      "use_smoothing": false,
      "window_size": 5,
      "tau_update": 0.5,
      "min_updates_per_class": 0.5,
      "temperature": 0.1,
      "use_pi": true,
      "dirichlet_alpha": 0.1,
      "_comment_part53": "=== Part 5.3: Init track STAD from global cache ===",
      "init_from_cache": true,
      "cache_match_threshold": 0.5,
      "_comment_fusion": "=== Part 5.2: 3-Source Fusion ===",
      "fusion_mode": "entropy_weighted",
      "fusion_init_weight": 0.1,
      "fusion_global_weight": 0.3,
      "fusion_track_weight": 0.6,
      "fusion_confidence_threshold": 0.7,
      "_comment_scores": "=== Score Modulation (same as instance_only) ===",
      "use_stad_adapted_scores": false,
      "use_track_score_modulation": true,
      "force_score_modulation": false,
      "score_blend_lambda": 0.5,
      "confirmed_track_boost": 0.07,
      "tentative_track_penalty": 0.0,
      "untracked_penalty": 0.01,
      "use_temporal_score_smoothing": true,
      "score_smoothing_alpha": 0.3,
      "score_smoothing_window": 5,
      "nms_threshold": 0.7,
      "visual_debug": false,
      "debug": false,
      "debug_every": 10
    }
  },
  "reset_on_video_change": true,
  "process_by_video": true
}
