{
    "description": "Temporal TTA configuration for SHIFT dataset evaluation",
    
    "data_root": "/media/fardad/T7 Touch/SHIFT/shift-dev/data",
    "split": "val",
    "output_dir": "./shift_temporal_tta_results",
    
    "filters": {
        "weather": ["clear", "rainy", "overcast", "foggy", "cloudy"],
        "time": ["daytime"],
        "max_frames_per_video": null
    },
    "max_samples": null,    
    "num_visualizations": 1000,
    
    "detector": {
        "name": "grounding-dino",
        "model_path": "IDEA-Research/grounding-dino-base",
        "target_classes": ["pedestrian", "car", "truck", "bus", "motorcycle", "bicycle"],
        "threshold": 0.10,
        "iou_threshold": 0.7
    },
    
    "adaptation": {
    "type": "temporal",
    "params": {
      "kappa_trans": 50.0,
      "kappa_ems": 10.0,
      "window_size": 5,
      "em_iterations": 3,
      "tau_update": 0.7,
      "fusion_mode": "entropy",
      "alpha": 0.0,
      "temperature": 15.0,
      "use_ema_kappa": true,
      "kappa_ema": 0.9,
      "update_after_nms": true,
      "debug_mode": true
    }
  },
  "reset_on_video_change": true,
  "process_by_video": true

}