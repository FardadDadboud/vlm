{
  "data_root": "/media/fardad/T7 Touch/SHIFT/shift-dev/data",
  "split": "val",
  "filters": {
    "weather": ["clear"],
    "time": ["daytime"],
    "max_frames_per_video": 50
  },
  "max_samples": 200,
  "detector": {
    "name": "grounding-dino",
    "model_path": "IDEA-Research/grounding-dino-base",
    "threshold": 0.1,
    "iou_threshold": 0.7,
    "target_classes": ["pedestrian", "car", "truck", "bus", "motorcycle", "bicycle"]
  },
  "adaptation": {
    "type": "none",
    "params": {}
  },
  "output_dir": "./shift_vanilla_results",
  "num_visualizations": 1000
}
